{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": ".venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["backend.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "env": {
        "PYTHONPATH": "."
      }
    },
    {
      "name": "streamlit",
      "runtimeExecutable": ".venv/Scripts/streamlit.exe",
      "runtimeArgs": ["run", "frontend/app.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501,
      "env": {
        "PYTHONPATH": "."
      }
    }
  ]
}
